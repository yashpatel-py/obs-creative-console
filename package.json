{
  "name": "obs-controller",
  "version": "0.1.0",
  "description": "A plugin created with the Logi Plugin SDK",
  "type": "module",
  "main": "./dist/index.mjs",
  "scripts": {
    "icons": "tsx src/generate-icons.ts",
    "build": "npm run icons && npm run typecheck && tsup",
    "build:pack": "npm run build:prod && npm run pack",
    "build:prod": "npm run icons && npm run typecheck && cross-env NODE_ENV=production tsup",
    "pack": "logitoolkit pack",
    "link": "logitoolkit link",
    "typecheck": "tsc --noEmit",
    "unlink": "logitoolkit unlink",
    "watch": "npm run typecheck && tsup --watch",
    "setup": "tsx src/setup.ts"
  },
  "author": "Your Name",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@logitech/plugin-sdk": "0.1.1",
    "obs-websocket-js": "^5.0.8"
  },
  "devDependencies": {
    "@logitech/plugin-toolkit": "0.1.1",
    "@types/node": "^22.18.8",
    "cross-env": "^7.0.3",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  }
}
